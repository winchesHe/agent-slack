# Slack（onboard 会询问，此处仅登记 key）
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# LiteLLM
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-...

# 可选
LOG_LEVEL=debug # trace, debug, info, warn, error
# 模型名（覆盖 config.yaml；default gpt-5.4）
AGENT_MODEL=gpt-5.4
# AI SDK provider 名称（默认 litellm），影响 providerOptions key
# PROVIDER_NAME=litellm
# 是否启用渲染调试（默认 false）
SLACK_RENDER_DEBUG=0 # 1 为启用，0 为禁用