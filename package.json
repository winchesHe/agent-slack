{
  "name": "@winches/agent-slack",
  "version": "0.1.6",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "agent-slack": "./bin/agent-slack.mjs"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/cli/index.ts",
    "dashboard:dev": "tsx watch src/cli/index.ts dashboard",
    "build": "tsdown",
    "build:dev": "tsdown --watch",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s && git add CHANGELOG.md",
    "release": "bumpp --execute=\"pnpm changelog\" --all --no-push && pnpm publish",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "tsx src/e2e/live/cli.ts",
    "e2e:interactive": "tsx src/e2e/live/cli.ts --interactive",
    "e2e:list": "tsx src/e2e/live/cli.ts --list",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "gen:examples": "tsx scripts/gen-examples.ts"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/openai": "^1.3.24",
    "@ai-sdk/openai-compatible": "^0.1.0",
    "@clack/prompts": "^1.2.0",
    "@slack/bolt": "^4.0.0",
    "@slack/web-api": "^7.15.1",
    "ai": "^4.0.0",
    "commander": "^14.0.3",
    "consola": "^3.2.0",
    "dotenv": "^16.4.0",
    "gray-matter": "^4.0.3",
    "markdown-to-slack-blocks": "^1.0.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "bumpp": "^9.11.1",
    "conventional-changelog-cli": "^4.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsdown": "^0.21.9",
    "tsx": "^4.16.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
